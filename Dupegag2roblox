    Callback = function(Value)
        AutoFarmStatus = Value
        if Value then
            AutoFarmThread = coroutine.create(AutoFarmLoop)
            coroutine.resume(AutoFarmThread)
            OrionLib:MakeNotification({
                Name = "🌾 Ферма активна",
                Content = "Сбор урожая запущен",
                Image = "rbxassetid://4483345998",
