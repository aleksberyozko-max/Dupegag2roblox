-- Поиск RemoteEvent
local RemoteEvent = nil
local possibleNames = {"ItemEvent", "Remote", "Network", "FruitHandler", "SeedRemote"}
for _, name in pairs(possibleNames) do
    local found = ReplicatedStorage:FindFirstChild(name)
    if found then RemoteEvent = found break end
end

if not RemoteEvent then
    -- Резервный метод через инструменты
    DupeService.FallbackMode = true
else
    DupeService.FallbackMode = false
end

-- Функция дупликации
function DupeService:DuplicateFruit(fruitName, count)
    if not fruitName or count < 1 then return false end
    
    -- Поиск предмета в инвентаре
    local targetItem = nil
    for _, item in pairs(Player:GetDescendants()) do
        if item:IsA("Tool") and item.Name:find(fruitName) then
            targetItem = item
            break
        end
    end
    
    if not targetItem then
        OrionLib:MakeNotification({
            Name = "Ошибка",
            Content = "Фрукт не найден в инвентаре",
            Image = "rbxassetid://4483345998",
            Time = 3
        })
        return false
    end
    
    -- Основной метод дупликации (десинхронизация)
    local success = 0
    for i = 1, count do
        if self.FallbackMode then
            -- Альтернативный метод через Backpack
            local clone = targetItem:Clone()
            clone.Parent = Backpack
            wait(0.1)
            targetItem.Parent = nil
            wait(0.1)
            clone.Parent = workspace
            wait(0.15)
            clone.Parent = Backpack
            success = success + 1
        else
            -- Основной метод через RemoteEvent
            RemoteEvent:FireServer("DropItem", targetItem)
            wait(0.08)
            RemoteEvent:FireServer("PickupItem", targetItem:Clone())
            wait(0.08)
            RemoteEvent:FireServer("StoreItem", targetItem)
            success = success + 1
        end
        wait(0.15)
    end
    
    return success > 0
end

