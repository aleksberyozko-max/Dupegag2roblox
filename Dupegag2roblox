-- Основной метод десинхронизации
local function DuplicateItem(item)
    if not item then return false end
    
    -- Отключаем обработку событий на время
    local oldParent = item.Parent
    item.Parent = nil
    wait(0.05)
    
    -- Создаём две копии
    local clone1 = item:Clone()
    local clone2 = item:Clone()
    
    -- Отправляем через Remote с задержкой
    RemoteEvent:FireServer("DropItem", item)
    wait(0.1)
    RemoteEvent:FireServer("PickupItem", clone1)
    wait(0.1)
    RemoteEvent:FireServer("StoreItem", clone2)
    
    -- Возвращаем оригинал
    item.Parent = oldParent
    clone1.Parent = Backpack
    clone2.Parent = Backpack
    
    return true
end

