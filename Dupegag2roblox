local FarmTab = Window:MakeTab({
    Name = "Ферма",
    Icon = "plant"
})

local AutoFarmStatus = false
local AutoFarmThread = nil

function AutoFarmLoop()
    while AutoFarmStatus do
        for _, obj in pairs(workspace:GetDescendants()) do
            if AutoFarmStatus and obj:IsA("Model") and obj.Name:find("Plant") then
                local harvest = obj:FindFirstChild("Harvest")
                if harvest then
                    local remote = ReplicatedStorage:FindFirstChild("HarvestRemote")
                    if remote then remote:FireServer(obj) end
                end
            end
        end
        wait(1)
    end
end

FarmTab:AddToggle({
